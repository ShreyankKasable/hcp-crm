# Groq — get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# Model (brief mandates gemma2-9b-it; llama-3.3-70b-versatile allowed as fallback)
GROQ_MODEL=gemma2-9b-it

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql://crm_user:crm_pass@localhost:5432/hcp_crm

# Langfuse (optional — leave blank to disable tracing). Free keys at https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com